# Copy to .env and fill in real values. .env is gitignored — never commit it.

# WeaponPaints MySQL (docker-compose.platform.yml, runs on the platform host)
WP_MYSQL_ROOT_PASSWORD=change-me
WP_MYSQL_DATABASE=weaponpaints
WP_MYSQL_USER=weaponpaints
WP_MYSQL_PASSWORD=change-me

# Game-host connection to that MySQL (must match WP_MYSQL_PASSWORD)
WP_DB_PASSWORD=change-me

# RCON password injected into every CS2 server container
RCON_PASSWORD=change-me

# API key for the NestJS platform backend
GAME_SERVER_API_KEY=change-me

# Optional: TBAntiCheat Discord webhook (https://discord.com/api/webhooks/<id>/<token>)
#ANTICHEAT_DISCORD_WEBHOOK=
